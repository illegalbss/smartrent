generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum OwnershipType {
  ORGANIZATION
  PERSONAL
}

// Residential properties hold Rooms rented to Tenants; Commercial properties
// ("Stores" in the UI) hold the same Room records rented to Shop Owners —
// same underlying tables, the UI just relabels and shows business fields.
enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
}

enum RoomStatus {
  VACANT
  OCCUPIED
}

enum RentFrequency {
  MONTHLY
  QUARTERLY
  YEARLY
}

// Distinguishes a residential Tenant from a commercial Shop Owner within the
// same occupants table (Tenant model) — the UI shows/requires different
// fields (business name, CAC number vs. next of kin) based on this.
enum OccupantType {
  RESIDENTIAL_TENANT
  SHOP_OWNER
}

enum PaymentStatus {
  PAID
  PARTIAL
  OWING
}

enum PaymentSource {
  MANUAL
  PAYSTACK
}

enum DocumentType {
  REFEREE_FORM
  TENANCY_AGREEMENT
  GOVERNMENT_ID
  PERSONAL_INFO_SHEET
  UTILITY_BILL
  INSPECTION_REPORT
  OTHER
}

enum ComplaintStatus {
  OPEN
  RESOLVED
}

enum ComplaintPriority {
  LOW
  MEDIUM
  HIGH
}

enum MaintenanceStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum ActorRole {
  LANDLORD
  SECRETARY
  TENANT
}

enum AuditAction {
  CREATED
  EDITED
  DELETED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELED
}

// How a landlord is paid out — determines which fields are required when
// calling Paystack's Create Subaccount API.
enum LandlordAccountType {
  INDIVIDUAL
  ORGANIZATION
}

enum TenantSubscriptionStatus {
  ACTIVE
  ATTENTION
  DISABLED
  CANCELED
}

enum BillingTransactionStatus {
  SUCCESS
  FAILED
  PENDING
}

// A single Super Admin (app owner) account type — separate login from
// Landlord/Secretary/Tenant, used only to manage the platform itself.
model SuperAdmin {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("super_admins")
}

// Fixed pricing tiers, stored in the database (not hardcoded) so the Super
// Admin can adjust price/room limits later without a code change.
// roomLimit null means unlimited (the Pro tier).
model SubscriptionPlan {
  id        String   @id @default(cuid())
  name      String   @unique
  roomLimit Int?     @map("room_limit")
  price     Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  landlords    Landlord[]
  transactions BillingTransaction[]

  @@map("subscription_plans")
}

// Every billing event (initial subscription payment, successful renewal, or
// a failed charge) — this is what powers the Super Admin's revenue view.
model BillingTransaction {
  id                String                   @id @default(cuid())
  landlordId        String                   @map("landlord_id")
  planId            String?                  @map("plan_id")
  amount            Decimal                  @db.Decimal(12, 2)
  status            BillingTransactionStatus
  paystackReference String                   @unique @map("paystack_reference")
  createdAt         DateTime                 @default(now()) @map("created_at")

  landlord Landlord          @relation(fields: [landlordId], references: [id], onDelete: Cascade)
  plan     SubscriptionPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@index([landlordId])
  @@index([status])
  @@map("billing_transactions")
}

model Landlord {
  id                       String             @id @default(cuid())
  name                     String
  email                    String             @unique
  passwordHash             String             @map("password_hash")
  phone                    String?
  planId                   String?            @map("plan_id")
  subscriptionStatus       SubscriptionStatus @default(ACTIVE) @map("subscription_status")
  nextBillingDate          DateTime?          @map("next_billing_date")
  paystackCustomerCode     String?            @map("paystack_customer_code")
  paystackSubscriptionCode String?            @map("paystack_subscription_code")

  // Payout setup (Paystack Subaccounts) — how rent collected online reaches
  // this landlord's own bank account. Distinct from paystackCustomerCode
  // above, which is for the landlord's own RentaFlow subscription billing.
  accountType            LandlordAccountType? @map("account_type")
  payoutBusinessName     String?              @map("payout_business_name")
  payoutBankCode         String?              @map("payout_bank_code")
  payoutAccountNumber    String?              @map("payout_account_number")
  payoutRcNumber         String?              @map("payout_rc_number")
  paystackSubaccountCode String?              @map("paystack_subaccount_code")
  payoutVerified         Boolean              @default(false) @map("payout_verified")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  plan                 SubscriptionPlan?     @relation(fields: [planId], references: [id], onDelete: SetNull)
  properties           Property[]
  secretaries          Secretary[]
  tenants              Tenant[]
  payments             Payment[]
  complaints           Complaint[]
  auditLogs            PaymentAuditLog[]
  maintenanceRequests  MaintenanceRequest[]
  notices              Notice[]
  houseRules           HouseRules[]
  paystackTransactions PaystackTransaction[]
  billingTransactions  BillingTransaction[]

  @@index([planId])
  @@map("landlords")
}

// Secretary/Accountant staff account, scoped to one landlord's portfolio.
model Secretary {
  id               String    @id @default(cuid())
  landlordId       String    @map("landlord_id")
  name             String
  email            String    @unique
  phone            String?
  passwordHash     String?   @map("password_hash")
  inviteToken      String?   @unique @map("invite_token")
  inviteAcceptedAt DateTime? @map("invite_accepted_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  landlord Landlord @relation(fields: [landlordId], references: [id], onDelete: Cascade)

  @@index([landlordId])
  @@map("secretaries")
}

model Property {
  id            String        @id @default(cuid())
  landlordId    String        @map("landlord_id")
  name          String
  address       String
  ownershipType OwnershipType @default(PERSONAL) @map("ownership_type")
  propertyType  PropertyType  @default(RESIDENTIAL) @map("property_type")
  photoUrl      String?       @map("photo_url")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  landlord   Landlord     @relation(fields: [landlordId], references: [id], onDelete: Cascade)
  rooms      Room[]
  notices    Notice[]
  houseRules HouseRules[]

  @@index([landlordId])
  @@map("properties")
}

model Room {
  id            String        @id @default(cuid())
  propertyId    String        @map("property_id")
  roomNumber    String        @map("room_number")
  rentAmount    Decimal       @map("rent_amount") @db.Decimal(12, 2)
  rentFrequency RentFrequency @default(YEARLY) @map("rent_frequency")
  status        RoomStatus    @default(VACANT)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenants  Tenant[]

  @@unique([propertyId, roomNumber])
  @@index([propertyId])
  @@map("rooms")
}

// The single occupants table — a residential Tenant and a commercial Shop
// Owner are the same record shape, distinguished by occupantType. Business
// fields (businessName, cacNumber) are only meaningful for SHOP_OWNER;
// next-of-kin fields are only meaningful for RESIDENTIAL_TENANT. The UI
// shows/requires the relevant subset based on occupantType.
model Tenant {
  id               String       @id @default(cuid())
  landlordId       String       @map("landlord_id")
  roomId           String?      @map("room_id")
  occupantType     OccupantType @default(RESIDENTIAL_TENANT) @map("occupant_type")
  name             String
  email            String       @unique
  phone            String?
  photoUrl         String?      @map("photo_url")
  passwordHash     String?      @map("password_hash")
  inviteToken      String?      @unique @map("invite_token")
  inviteAcceptedAt DateTime?    @map("invite_accepted_at")
  dateCommencement DateTime?    @map("date_commencement")
  dateExpiration   DateTime?    @map("date_expiration")
  dateRenewal      DateTime?    @map("date_renewal")
  securityDeposit  Decimal?     @map("security_deposit") @db.Decimal(12, 2)
  businessName     String?      @map("business_name")
  cacNumber        String?      @map("cac_number")
  nextOfKinName    String?      @map("next_of_kin_name")
  nextOfKinPhone   String?      @map("next_of_kin_phone")
  registeredById   String?      @map("registered_by_id")
  registeredByRole ActorRole?   @map("registered_by_role")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  landlord             Landlord              @relation(fields: [landlordId], references: [id], onDelete: Cascade)
  room                 Room?                 @relation(fields: [roomId], references: [id], onDelete: SetNull)
  payments             Payment[]
  documents            Document[]
  complaints           Complaint[]
  maintenanceRequests  MaintenanceRequest[]
  notices              Notice[]
  paystackTransactions PaystackTransaction[]
  subscription         TenantSubscription?

  @@index([landlordId])
  @@index([roomId])
  @@map("tenants")
}

// A tenant/shop-owner's recurring rent subscription (Paystack), created once
// they opt into auto-pay matching their room's rentFrequency. next_charge_date
// and status are kept in sync via Paystack's subscription webhooks.
model TenantSubscription {
  id               String                   @id @default(cuid())
  tenantId         String                   @unique @map("tenant_id")
  subscriptionCode String                   @unique @map("subscription_code")
  emailToken       String?                  @map("email_token")
  nextChargeDate   DateTime?                @map("next_charge_date")
  status           TenantSubscriptionStatus @default(ACTIVE)
  createdAt        DateTime                 @default(now()) @map("created_at")
  updatedAt        DateTime                 @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_subscriptions")
}

// Editable and deletable, unlike an append-only ledger — every edit/delete
// writes a PaymentAuditLog entry so mistakes stay traceable.
model Payment {
  id                 String        @id @default(cuid())
  landlordId         String        @map("landlord_id")
  tenantId           String        @map("tenant_id")
  roomId             String        @map("room_id")
  amount             Decimal       @db.Decimal(12, 2)
  datePaid           DateTime      @map("date_paid")
  coverageStart      DateTime?     @map("coverage_start")
  coverageEnd        DateTime?     @map("coverage_end")
  status             PaymentStatus @default(PAID)
  source             PaymentSource @default(MANUAL)
  paystackReference  String?       @unique @map("paystack_reference")
  // The 1% (capped at ₦25,000) RentaFlow kept from this payment, if any —
  // null for manual payments. Powers the Super Admin revenue view.
  platformFeeCharged Decimal?      @map("platform_fee_charged") @db.Decimal(12, 2)
  notes              String?
  createdById        String        @map("created_by_id")
  createdByRole      ActorRole     @map("created_by_role")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  landlord  Landlord          @relation(fields: [landlordId], references: [id], onDelete: Cascade)
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  auditLogs PaymentAuditLog[]

  @@index([landlordId])
  @@index([tenantId])
  @@map("payments")
}

// Kept even after a payment is deleted (payment relation becomes null via
// SetNull) so the trail survives the record it describes.
model PaymentAuditLog {
  id              String      @id @default(cuid())
  paymentId       String?     @map("payment_id")
  landlordId      String      @map("landlord_id")
  action          AuditAction
  performedById   String      @map("performed_by_id")
  performedByRole ActorRole   @map("performed_by_role")
  performedByName String      @map("performed_by_name")
  previousData    Json?       @map("previous_data")
  newData         Json?       @map("new_data")
  createdAt       DateTime    @default(now()) @map("created_at")

  payment  Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  landlord Landlord @relation(fields: [landlordId], references: [id], onDelete: Cascade)

  @@index([landlordId])
  @@index([paymentId])
  @@map("payment_audit_logs")
}

// Uploaded files (referee form, ID, personal info sheet) plus a record of
// on-demand-generated tenancy agreements. Secretary/Landlord access only —
// enforced at the API layer, never exposed to tenant-facing routes.
model Document {
  id             String       @id @default(cuid())
  tenantId       String       @map("tenant_id")
  type           DocumentType
  fileName       String       @map("file_name")
  fileUrl        String       @map("file_url")
  mimeType       String?      @map("mime_type")
  sizeBytes      Int?         @map("size_bytes")
  uploadedById   String       @map("uploaded_by_id")
  uploadedByRole ActorRole    @map("uploaded_by_role")
  createdAt      DateTime     @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("documents")
}

model Complaint {
  id             String            @id @default(cuid())
  landlordId     String            @map("landlord_id")
  tenantId       String            @map("tenant_id")
  message        String
  status         ComplaintStatus   @default(OPEN)
  priority       ComplaintPriority @default(MEDIUM)
  category       String?
  assignedToId   String?           @map("assigned_to_id")
  assignedToRole ActorRole?        @map("assigned_to_role")
  assignedToName String?           @map("assigned_to_name")
  response       String?
  respondedAt    DateTime?         @map("responded_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  landlord Landlord @relation(fields: [landlordId], references: [id], onDelete: Cascade)
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([landlordId])
  @@index([tenantId])
  @@map("complaints")
}

model MaintenanceRequest {
  id          String            @id @default(cuid())
  landlordId  String            @map("landlord_id")
  tenantId    String            @map("tenant_id")
  title       String
  description String
  status      MaintenanceStatus @default(PENDING)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  resolvedAt  DateTime?         @map("resolved_at")

  landlord Landlord @relation(fields: [landlordId], references: [id], onDelete: Cascade)
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([landlordId])
  @@index([tenantId])
  @@map("maintenance_requests")
}

enum NoticeSeverity {
  INFO
  WARNING
  VACATE_NOTICE
}

// A message from Landlord/Secretary. Exactly one target: everyone in the
// portfolio (propertyId and tenantId both null), everyone at one property
// (propertyId set), or one specific tenant (tenantId set) — e.g. a personal
// warning or notice to vacate that shouldn't be seen by anyone else.
model Notice {
  id            String         @id @default(cuid())
  landlordId    String         @map("landlord_id")
  propertyId    String?        @map("property_id")
  tenantId      String?        @map("tenant_id")
  severity      NoticeSeverity @default(INFO)
  title         String
  message       String
  createdById   String         @map("created_by_id")
  createdByRole ActorRole      @map("created_by_role")
  createdAt     DateTime       @default(now()) @map("created_at")

  landlord Landlord  @relation(fields: [landlordId], references: [id], onDelete: Cascade)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant   Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([landlordId])
  @@index([propertyId])
  @@index([tenantId])
  @@map("notices")
}

// A standing reference document, not a timestamped alert — general house
// rules (propertyId null) or an override specific to one property.
model HouseRules {
  id            String    @id @default(cuid())
  landlordId    String    @map("landlord_id")
  propertyId    String?   @map("property_id")
  content       String
  updatedById   String    @map("updated_by_id")
  updatedByRole ActorRole @map("updated_by_role")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  landlord Landlord  @relation(fields: [landlordId], references: [id], onDelete: Cascade)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([landlordId])
  @@index([propertyId])
  @@map("house_rules")
}

// Created when a tenant starts a Paystack payment, before it's known to have
// succeeded. Lets both the client-side verify call AND the server-side
// webhook (which can fire even after the tenant closes their browser, e.g.
// for a bank transfer or USSD payment completed later) resolve a bare
// transaction reference back to which tenant/room it belongs to.
model PaystackTransaction {
  id         String    @id @default(cuid())
  reference  String    @unique
  tenantId   String    @map("tenant_id")
  landlordId String    @map("landlord_id")
  roomId     String    @map("room_id")
  amount     Decimal   @db.Decimal(12, 2)
  consumedAt DateTime? @map("consumed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  landlord Landlord @relation(fields: [landlordId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([landlordId])
  @@map("paystack_transactions")
}
