DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/postgres"

PORT=4000
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
# Auth endpoint rate limit per 15-minute window per IP. Keep low (~20) in production;
# raise for local development to avoid tripping the limiter during manual testing.
AUTH_RATE_LIMIT=20

# Paystack test-mode keys from https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_test_replace_me
PAYSTACK_PUBLIC_KEY=pk_test_replace_me
